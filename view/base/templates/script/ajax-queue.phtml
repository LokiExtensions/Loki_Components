<?php
declare(strict_types=1);

/** @version 2.4.1 */

use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;
use Loki\Components\Config\Config;
use Loki\Components\Factory\ViewModelFactory;
use Loki\Components\Util\ComponentUtil;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelFactory $viewModelFactory */
/** @var Config $config */
/** @var ComponentUtil $componentUtil */

$config = $viewModelFactory->create(Config::class);
$componentUtil = $viewModelFactory->create(ComponentUtil::class);

$interval = (int)$block->getInterval();
if ($interval < 10) {
    $interval = 40;
}
?>
<script>
    const LokiAjaxQueue = {
        requests: [],
        interval: <?= (int)$interval ?>,
        loading: false,
        activeElementId: false,
        add(component, update) {
            if (component.skipQueue) {
                this.post([{component, update}]);
                return;
            }

            this.requests.push({
                component,
                update,
            });

            if (component.lazyUpdate && component.lazyUpdateTimeout > 0) {
                setTimeout(async () => {
                    component.lazyUpdate = false;
                }, component.lazyUpdateTimeout);
            }
        },
        run() {
            document.addEventListener('focusin', (e) => {
                if (['input', 'textarea', 'select'].includes(e.target.tagName.toLowerCase())) {
                    if (e.target.id) {
                        this.activeElementId = e.target.id;
                    }
                } else {
                    this.activeElementId = false;
                }
            });

            setInterval(async () => {
                await this.postQueue();
            }, this.interval);
        },
        setLoading(loading) {
            this.loading = loading;
            document.dispatchEvent(new CustomEvent('loki-components.ajax.loading', {detail: loading}));
        },
        async postQueue() {
            if (!this.requests.length > 0) {
                return;
            }

            const requests = this.requests;
            const hasNonLazyUpdate = requests.some(request => request.component.lazyUpdate === false);
            if (false === hasNonLazyUpdate) {
                return;
            }

            requests.forEach(request => {
                request.component.beforePost();
            });

            this.requests = [];
            this.post(requests);
        },
        async post(incomingRequests) {
            this.setLoading(true);

            requests = incomingRequests.filter(request => !request.component.skipAjax);
            if (requests.length === 0) {
                this.afterPostSuccess(incomingRequests);
                this.afterPostFinally(incomingRequests);
                return;
            }

            const formKey = Alpine.store('LokiComponents').formKey;
            await fetch('<?= $escaper->escapeUrl($componentUtil->getPostUrl(
            )) ?>?form_key=' + formKey + '&isAjax=true', {
                method: 'POST',
                mode: 'same-origin',
                headers: this.getPostHeaders(),
                body: JSON.stringify(this.buildBody(requests))
            })
                .then(async response => {
                    const formKey = response.headers.get('x-magento-form-key');
                    if (formKey) {
                        Alpine.store('LokiComponents').formKey = formKey;
                    }

                    const body = await response.text();
                    if (response.ok) {
                        return body;
                    }

                    LokiComponentsLogger.error('Fetch error', response);

                    const error = new Error(response.statusText);
                    error.status = response.status;
                    error.body = body;
                    throw error;
                })
                .then(html => {
                    try {
                        const data = JSON.parse(html);
                        if (data) {
                            this.handleJson(data);
                            return;
                        }
                    } catch (e) {
                    }

                    this.updateTargetsAfterPost(requests, html);
                    this.afterPostSuccess(incomingRequests);
                })
                .catch(error => {
                    let errorMessage = error.name;
                    if (error.body) {
                        errorMessage = error.body.split(/\r?\n/)[0];
                    }

                    Alpine.store('Message').addErrorMessage(errorMessage);
                })
                .finally(() => {
                    this.afterPostFinally(incomingRequests);
                });
        },
        afterPostSuccess(requests) {
            requests.forEach(request => {
                request.component.afterPostSuccess();
            });
        },
        afterPostFinally(requests) {
            requests.forEach(request => {
                request.component.afterPostFinally();
            });

            this.setLoading(false);
            document.dispatchEvent(new CustomEvent('loki-components.ajax.done'));
        },
        getPostHeaders() {
            return {
                'X-Alpine-Request': true,
                'X-Requested-With': 'XMLHttpRequest',
                'Content-Type': 'application/json'
            };
        },
        buildBody(requests) {
            return {
                updates: this.getUpdates(requests),
                targets: this.getTargets(requests),
                handles: <?= /* @noEscape */ json_encode(
                    $componentUtil->getHandles($block)
                ) ?>,
                pageHandles: <?= /* @noEscape */ json_encode(
                    $componentUtil->getPageHandles($block)
                ) ?>,
                request: <?= /* @noEscape */ json_encode(
                    $componentUtil->getRequestData()
                ) ?>,
                signature: <?= /* @noEscape */ json_encode(
                    $componentUtil->getSignature($block)
                ) ?>
            };
        },
        handleJson(data) {
            if (data.error) {
                LokiComponentsLogger.error(data.error);
                Alpine.store('Message').addErrorMessage(data.error);
            }

            if (data.redirect) {
                document.location.assign(data.redirect);
            }
        },
        getUpdates(requests) {
            const updates = [];
            requests.forEach(request => {
                updates.push({
                    blockName: request.component.blockId,
                    update: request.update,
                });
            });

            return updates;
        },
        getTargets(requests) {
            const targets = [];
            requests.forEach(request => {
                request.component.targets.forEach(target => {
                    targets.push(target);
                })
            });

            return [...new Set(targets)];
        },
        updateTargetsAfterPost(requests, html) {
            const parser = new DOMParser();
            const ajaxDocument = parser.parseFromString(html, "text/html");

            const messageScript = ajaxDocument.querySelector('script[type="text/x-loki-messages"]');
            if (messageScript) {
                const messages = JSON.parse(messageScript.innerHTML);
                messages.forEach((message) => {
                    Alpine.store('Message').addMessage(message.type, message.text);
                });
            }

            this.getTargets(requests).forEach(target => {
                const targetElement = document.getElementById(target);
                const newTargetElement = ajaxDocument.getElementById(target);

                if (!targetElement || !newTargetElement) {
                    return;
                }

                const targetComponent = Alpine.store('LokiComponents').getComponentByElementId(target);
                if (targetComponent) {
                    targetComponent.destroy();
                }

                Alpine.mutateDom(() => {
                    LokiHtmlReplacer.replace(targetElement, newTargetElement);
                    Alpine.destroyTree(targetElement);
                    Alpine.initTree(targetElement);
                });
            });

            if (this.activeElementId) {
                const activeElement = document.getElementById(this.activeElementId);
                if (activeElement) {
                    activeElement.focus();
                    try {
                        activeElement.selectionStart = activeElement.selectionEnd = activeElement.value.length;
                    } catch (e) {
                    }
                }
            }
        }
    };

    LokiAjaxQueue.run();
</script>
