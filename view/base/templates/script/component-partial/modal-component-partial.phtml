<?php
declare(strict_types=1);

/** @version 2.5.0 */

use Magento\Framework\View\Element\Template;

/** @var Template $block */
?>
<script>
    const LokiModalComponentPartial = {
        initModalClosing() {
            if (!this.$refs.modal) {
                return;
            }

            if (this.getModalState()) {
                this.openModal();
            }

            this.$refs.modal.addEventListener('cancel', (event) => {
                this.closeModal();
                event.preventDefault();
            });

            this.$refs.modal.addEventListener('click', (event) => {
                if (event.target === this.$refs.modal) {
                    this.closeModal();
                    event.preventDefault();
                }
            });
        },
        setModalState(state) {
            if (state) {
                this.$refs.modal.showModal();
            } else {
                this.$refs.modal.close();
            }

            this.saveModalState();
        },
        toggleModal() {
            this.setModalState(!this.isModalOpen());
        },
        closeModal() {
            this.setModalState(false);
        },
        openModal() {
            this.setModalState(true);
            this.$refs.modal.dispatchEvent(new CustomEvent('open'));
        },
        isModalOpen() {
            return !!this.$refs.modal.open;
        },
        isModalClosed() {
            return !this.isModalOpen();
        },
        saveModalState() {
            const modals = JSON.parse(localStorage.getItem('loki-modals')) ?? {};
            if (this.isModalOpen()) {
                modals[this.$root.id] = true;
            } else {
                delete modals[this.$root.id];
            }

            localStorage.setItem('loki-modals', JSON.stringify(modals));
        },
        getModalState() {
            const modals = JSON.parse(localStorage.getItem('loki-modals')) ?? {};
            return modals[this.$root.id] ?? false;
        }
    };
</script>
