<?php
declare(strict_types=1);

use Magento\Framework\View\Element\Template;

/** @version 2.2.60 */
/** @var Template $block */
?>
<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('LokiToggle', () => ({
            shown: false,
            hidden() {
                return !this.shown;
            },
            show() {
                this.shown = true;
            },
            hide() {
               this.shown = false;
            },
            toggle() {
                this.shown = !this.shown;
            }
        }));
    });
</script>
